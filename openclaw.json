{
  // ═══════════════════════════════════════════════════════════════
  // OpenClaw KaanAssist Mod — Configuration
  // codexlb load balancer → GPT 5.4 (primary) + GPT 5.4 mini (fast)
  // Same architecture as Retena mod, different personality + MCP
  // CRITICAL: NO "plugins.allow" key — it kills bundled plugins
  // ═══════════════════════════════════════════════════════════════

  // ── Custom provider: codexlb (via smart router) ───────────────
  models: {
    providers: {
      "codexlb": {
        baseUrl: "http://127.0.0.1:18792/v1",
        apiKey: "${CODEX_LB_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "gpt-5.4",
            name: "GPT-5.4",
            reasoning: true,
            input: ["text", "image"],
            contextWindow: 272000,
            maxTokens: 32768,
            compat: {},
          },
          {
            id: "gpt-5.4-mini",
            name: "GPT-5.4 Mini",
            reasoning: true,
            input: ["text", "image"],
            contextWindow: 272000,
            maxTokens: 32768,
            compat: {},
          },
        ],
      },
      "groq": {
        baseUrl: "https://api.groq.com/openai/v1",
        apiKey: "${GROQ_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "llama-3.3-70b-versatile",
            name: "Llama 3.3 70B",
            input: ["text"],
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
      "cerebras": {
        baseUrl: "https://api.cerebras.ai/v1",
        apiKey: "${CEREBRAS_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "llama3.1-8b",
            name: "Llama 3.1 8B (Cerebras)",
            input: ["text"],
            contextWindow: 8192,
            maxTokens: 8192,
          },
          {
            id: "llama-3.3-70b",
            name: "Llama 3.3 70B (Cerebras)",
            input: ["text"],
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  // ── Agent config ──────────────────────────────────────────────
  agents: {
    defaults: {
      model: {
        primary: "codexlb/gpt-5.4",
        fallbacks: [
          "codexlb/gpt-5.4-mini",
          "groq/llama-3.3-70b-versatile",
          "cerebras/llama-3.3-70b",
        ],
      },
      models: {
        "codexlb/gpt-5.4": { alias: "Big" },
        "codexlb/gpt-5.4-mini": { alias: "Mini" },
        "groq/llama-3.3-70b-versatile": { alias: "Groq" },
        "cerebras/llama3.1-8b": { alias: "Fast" },
      },
      workspace: "/root/.openclaw/workspace",
      heartbeat: {
        every: "4h",
        target: "last",
      },
    },
  },

  // ── Telegram channel ──────────────────────────────────────────
  channels: {
    telegram: {
      enabled: true,
      // botToken injected via TELEGRAM_BOT_TOKEN env var
      streaming: "off",
    },
  },

  // ── Session config ────────────────────────────────────────────
  session: {
    dmScope: "main",
    reset: {
      mode: "idle",
      idleMinutes: 120,
    },
    compaction: {
      enabled: true,
      threshold: 0.65,
    },
  },

  // ── Gateway ───────────────────────────────────────────────────
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      dangerouslyAllowHostHeaderOriginFallback: true,
    },
  },

  // ── Browser tooling ─────────────────────────────────────────
  browser: {
    enabled: true,
    executablePath: "/usr/bin/chromium",
    headless: true,
    args: [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu",
      "--single-process",
    ],
  },

  // ── MCP Servers ───────────────────────────────────────────────
  mcp: {
    servers: {
      "notion": {
        command: "npx",
        args: ["-y", "@notionhq/notion-mcp-server"],
        env: {
          "NOTION_TOKEN": "${NOTION_TOKEN}",
        },
      },
    },
  },

  // ── Plugins — NEVER add "allow" key here ──────────────────────
  // CRITICAL: NO "allow" key — it acts as allowlist for ALL plugins
  // including bundled ones like Telegram (Issue #57219)
  plugins: {
    entries: {
      "memory-openviking": {
        enabled: true,
        config: {
          mode: "local",
          configPath: "/root/.openviking/ov.conf",
          port: 1933,
          autoCapture: true,
          autoRecall: true,
          recallLimit: 10,
          captureMode: "semantic",
        },
      },
    },
    slots: {
      // OpenViking memory — uses FREE Gemini embeddings (GEMINI_API_KEY)
      // + FREE Groq VLM for summaries (GROQ_API_KEY)
      memory: "memory-openviking",
    },
  },

  // ── Web search (Gemini free tier) ─────────────────────────────
  webSearch: {
    provider: "gemini",
    apiKey: "${GEMINI_API_KEY}",
  },
}
