{
  // ═══════════════════════════════════════════════════════════════
  // OpenClaw KaanAssist Mod v2 — Configuration
  // codexlb load balancer → GPT 5.4 (primary) + GPT 5.4 mini (fast)
  // Same architecture as Retena mod, different personality + MCP
  // CRITICAL: NO "plugins.allow" key — it kills bundled plugins
  // ═══════════════════════════════════════════════════════════════

  // ── Custom provider: codexlb (via smart router) ───────────────
  models: {
    providers: {
      "codexlb": {
        baseUrl: "http://127.0.0.1:18792/v1",
        apiKey: "${CODEX_LB_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "gpt-5.4",
            name: "GPT-5.4",
            reasoning: true,
            input: ["text", "image"],
            contextWindow: 272000,
            maxTokens: 32768,
            compat: {},
          },
          {
            id: "gpt-5.4-mini",
            name: "GPT-5.4 Mini",
            reasoning: true,
            input: ["text", "image"],
            contextWindow: 272000,
            maxTokens: 32768,
            compat: {},
          },
        ],
      },
    },
  },

  // ── Agent config ──────────────────────────────────────────────
  agents: {
    defaults: {
      model: {
        primary: "codexlb/gpt-5.4",
        fallbacks: [
          "codexlb/gpt-5.4-mini",
        ],
      },
      models: {
        "codexlb/gpt-5.4": { alias: "Big" },
        "codexlb/gpt-5.4-mini": { alias: "Mini" },
      },
      workspace: "/root/.openclaw/workspace",
      heartbeat: {
        every: "4h",
        target: "last",
      },
    },
  },

  // ── Telegram channel (new streaming format) ─────────────────
  channels: {
    telegram: {
      enabled: true,
      streaming: {
        mode: "off",
      },
    },
  },

  // ── Session config ────────────────────────────────────────────
  session: {
    dmScope: "main",
    reset: {
      mode: "idle",
      idleMinutes: 120,
    },
  },

  // ── Gateway ───────────────────────────────────────────────────
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      dangerouslyAllowHostHeaderOriginFallback: true,
    },
  },

  // ── Browser (flags via CHROMIUM_FLAGS env var) ───────────────
  browser: {
    enabled: true,
    executablePath: "/usr/bin/chromium",
    headless: true,
  },

  // ── Web search (top-level) ──────────────────────────────────
  webSearch: {
    provider: "gemini",
  },

  // ── MCP Servers ───────────────────────────────────────────────
  mcp: {
    servers: {
      "notion": {
        command: "npx",
        args: ["-y", "@notionhq/notion-mcp-server"],
        env: {
          "NOTION_TOKEN": "${NOTION_TOKEN}",
        },
      },
    },
  },

  // ── Plugins — NEVER add "allow" key here ──────────────────────
  plugins: {
    enabled: true,
    slots: {
      // Set to "none" for clean boot. Bot installs OpenViking via ov-install post-deploy.
      memory: "none",
    },
  },

  // ── Environment variables ─────────────────────────────────────
  env: {
    vars: {
      CLAUDE_CODE_USE_OPENAI: "1",
      CHROMIUM_FLAGS: "--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage --disable-gpu --single-process",
    },
  },
}
